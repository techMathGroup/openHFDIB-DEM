}

virtualMesh
{
    level 0;
    charCellSize 0.0005;
    recordContact false;
}
sphere_Top1
{

	fullyCoupledBody;
	// {
		// velocity (0 -1.0 0);
	// }

	rho         rho [1 -3 0 0 0 0 0] 10000;

	refineMC 5;

	U
	{
	BC  noSlip;
	}

	bodyAddition
	{
		addModel   once;
		onceCoeffs{}
	}
		
	material particle1;
    // bodyGeom convex;
	bodyGeom sphere;
	sphere
	{
	    startPosition   (0.0 0.015 0.0);
	    radius  0.01;
	}

	updateTorque false;
	sdBasedLambda false;
	interfaceSpan 1.0;
	startSynced false;
	refineBuffers 5;
