FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      HFDIBDEMDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

bodyNames ("sphere_Top1");

interpolationSchemes
{
  U cell;
}

surfaceThreshold    1e-4;
stepDEM     0.2;
geometricD (1 1 1);
recordSimulation true;
recordFirstTimeStep true;

outputSetup
{
    basic true;
    iB  true;
    DEM false;
    addModel false;
    parallelDEM false;
}

DEM
{
	LcCoeff 0.55;
	rotationModel mindlin1953;
	
    materials
    {
        particle1
        {
            Y       1e8;
            nu      0.5;
            gamma   0.0;
            mu      0.0;
            adhN    0;
			// eps	 	0.965;
			eps	 	1.0;
        }

        semiIron
        {
            Y       1e8;

            nu      0.0;
            gamma   0.0;
            mu      0.0;
            adhN    0;
			// eps	 	0.965;
			eps	 	1.0;
        }    
    }

